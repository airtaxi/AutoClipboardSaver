<?xml version="1.0" encoding="utf-8" ?>
<winuiex:WindowEx
    x:Class="AutoClipboardSaver.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:AutoClipboardSaver"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tb="using:H.NotifyIcon"
    xmlns:winuiex="using:WinUIEx"
    MinHeight="0"
    Closed="OnClosed"
    IsMaximizable="False"
    IsMinimizable="False"
    IsResizable="False"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Loaded="OnRootElementLoaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <tb:TaskbarIcon
            x:Name="TaskbarIcon"
            ContextMenuMode="SecondWindow"
            MenuActivation="RightClick"
            NoLeftClickDelay="True">
            <tb:TaskbarIcon.IconSource>
                <tb:GeneratedIconSource BackgroundSource="ms-appx:///Assets/logo.png" />
            </tb:TaskbarIcon.IconSource>
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout AreOpenCloseAnimationsEnabled="True">
                    <MenuFlyoutItem x:Uid="AuthorMenuFlyoutItem" IsEnabled="False" />
                    <MenuFlyoutItem x:Uid="OpenSettingsMenuFlyoutItem">
                        <MenuFlyoutItem.Command>
                            <XamlUICommand ExecuteRequested="OnOnOpenSettingsWindowMenuFlyoutItemClicked" />
                        </MenuFlyoutItem.Command>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:Uid="CloseMenuFlyoutItem">
                        <MenuFlyoutItem.Command>
                            <XamlUICommand ExecuteRequested="OnCloseProgramMenuFlyoutItemClicked" />
                        </MenuFlyoutItem.Command>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>

        <TitleBar
            x:Name="AppTitleBar"
            x:Uid="AppTitleBar"
            Grid.Row="0"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="False">
            <TitleBar.RightHeader>
                <ToggleSwitch
                    x:Name="ServiceToggleSwitch"
                    x:Uid="ServiceToggleSwitch"
                    Margin="4,0,0,0"
                    IsOn="True"
                    Toggled="OnServiceToggleSwitchToggled" />
            </TitleBar.RightHeader>
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/logo.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <Frame x:Name="AppFrame" Grid.Row="1" />
    </Grid>
</winuiex:WindowEx>
